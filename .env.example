ESLINT_NO_DEV_ERRORS=true

# TMDB API key (https://www.themoviedb.org/settings/api)
REACT_APP_TMDB_KEY=your_tmdb_api_key_here

# OAuth redirect after TMDB login — must match exactly what you whitelist in TMDB app settings.
# Local dev (npm start, port 3000):
REACT_APP_TMDB_REDIRECT_URL=http://localhost:3000/approved

# Docker (docker compose, port 8080) — TMDB callback must match:
# REACT_APP_TMDB_REDIRECT_URL=http://localhost:8080/approved
